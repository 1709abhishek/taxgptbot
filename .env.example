# TaxGPT Financial Chatbot - Environment Variables
# Copy this file to backend/.env and fill in your API keys

# =============================================================================
# REQUIRED API KEYS
# =============================================================================

# Anthropic API Key (for Claude LLM)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API Key (fallback LLM provider)
# Get yours at: https://platform.openai.com/
OPENAI_API_KEY=sk-proj-your-key-here

# Voyage AI API Key (for finance-specific embeddings)
# Get yours at: https://dash.voyageai.com/
VOYAGE_API_KEY=pa-your-key-here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# ChromaDB persistence directory (relative to backend/)
CHROMA_PERSIST_DIR=./data/chroma_db

# Graph persistence path (relative to backend/)
GRAPH_PERSIST_PATH=./data/graph.pkl

# =============================================================================
# EMBEDDING CONFIGURATION
# =============================================================================

# Embedding provider: voyage (recommended), openai, or local
EMBEDDING_PROVIDER=voyage

# Embedding model
# Voyage: voyage-finance-2 (recommended for financial data)
# OpenAI: text-embedding-3-large
# Local: all-mpnet-base-v2
EMBEDDING_MODEL=voyage-finance-2

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# LLM Provider: openai or anthropic
LLM_PROVIDER=openai

# LLM Model
# OpenAI: gpt-4o (recommended), gpt-4o-mini
# Anthropic: claude-sonnet-4-20250514, claude-haiku-3-5-20241022
LLM_MODEL=gpt-4o

# =============================================================================
# LOW MEMORY MODE (for 8GB machines like Mac M2)
# =============================================================================

# Enable low memory mode for large file processing
LOW_MEMORY_MODE=true

# Number of parallel workers for PDF processing (reduce for low memory)
LOW_MEMORY_MAX_WORKERS=2

# Pages to process per batch
LOW_MEMORY_PAGE_BATCH_SIZE=50

# Embeddings per API call (reduce if hitting token limits)
LOW_MEMORY_EMBEDDING_BATCH_SIZE=8

# Vectors per ChromaDB insert
LOW_MEMORY_VECTOR_BATCH_SIZE=500

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
